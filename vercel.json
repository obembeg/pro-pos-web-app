{
  "version": 2,
  "cleanUrls": true,
  "headers": [
    {
      "source": "/downloads/:path*.apk",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/vnd.android.package-archive"
        },
        {
          "key": "Content-Disposition",
          "value": "attachment"
        }
      ]
    }
  ]
}